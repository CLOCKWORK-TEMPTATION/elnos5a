NODE_ENV=test
TEST_LOG_LEVEL=info
TEST_LOG_FILE=./test-results/test-run.log
MISTRAL_API_KEY=__DUMMY__
ANTHROPIC_API_KEY=sk-ant-test-placeholder-key-1234567890
OPENAI_API_KEY=sk-test-placeholder-key-1234567890
GEMINI_API_KEY=gemini-test-placeholder-key
DEEPSEEK_API_KEY=deepseek-test-placeholder-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
AGENT_REVIEW_MODEL=anthropic:claude-sonnet-4-6
AGENT_REVIEW_FALLBACK_MODEL=openai:gpt-5-mini
FINAL_REVIEW_MODEL=anthropic:claude-sonnet-4-6
FINAL_REVIEW_FALLBACK_MODEL=google-genai:gemini-2.5-flash
NEXT_PUBLIC_APP_PORT=3000
TEST_FIXTURES_DIR=./tests/fixtures
TEST_TIMEOUT_MS=30000
NEXT_PUBLIC_AGENT_REVIEW_FAIL_OPEN=true

# E2E audit execution
E2E_TARGET_URL=http://127.0.0.1:3000
APP_BASE_URL=http://127.0.0.1:3000
E2E_AUDIT_REPORT_DIR=./test-results
E2E_AUDIT_SCREENSHOT_DIR=./test-results/e2e-audit-screenshots
E2E_AUDIT_TIMEOUT_MS=180000
E2E_AUDIT_STRICT_MODE=false
E2E_AUDIT_ALLOWED_FAILED=0
E2E_AUDIT_ALLOWED_PARTIAL=9999
E2E_AUDIT_MIN_PASS_RATE=0
